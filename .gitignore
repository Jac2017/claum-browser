# Build output — created inside the ungoogled-chromium checkout, never here
build/
out/
*.app/
*.dmg
*.exe
*.msi

# OS cruft
.DS_Store
Thumbs.db

# Editor cruft
.vscode/
.idea/
*.swp

# Generated from sources (do not commit)
claum/extensions/*/_generated_*
claum/resources/**/_bundle_*

# Node / npm if you use them for extension dev
node_modules/
*.log

# ----------------------------------------------------------------------
# GitHub personal access token used by Claude sessions for push auth.
# NEVER commit this. The token sits alongside the repo so any Claude
# session (including scheduled watchers in other session ids) can read
# it at a known shared path.
# ----------------------------------------------------------------------
.gh_token
*.gh_token
