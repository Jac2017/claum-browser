{
  "manifest_version": 3,
  "name": "Claum",
  "short_name": "Claum",
  "version": "1.0.0",
  "version_name": "1.0.0 (claum)",
  "description": "Claum's glass-morphism new tab, vertical sidebar, and settings surface.",

  "permissions": [
    "tabs",
    "sidePanel",
    "storage",
    "favicon",
    "bookmarks",
    "history",
    "topSites",
    "declarativeNetRequest",
    "identity",
    "identity.email"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_frames",
      "enabled": true,
      "path": "rules.json"
    }]
  },

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "action": {
    "default_title": "Claum sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "background": {
    "service_worker": "background.js"
  },

  "sandbox": {
    "pages": ["ads/ad-frame.html"]
  },

  "content_security_policy": {
    "sandbox": "sandbox allow-scripts allow-popups; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self'"
  }
}
